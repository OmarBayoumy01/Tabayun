# Base URL of the FastAPI backend (served via Uvicorn, default port 8000).
# The endpoints (/auth/login, /detect/image, /detect/video, /feedback, /health)
# are served from here. Interactive API docs: <VITE_API_URL>/docs
#
# Copy this file to .env and set the URL to your running backend, e.g.:
#   VITE_API_URL=http://localhost:8000
#
# Note: Vite only exposes variables prefixed with VITE_. Restart the dev
# server after changing this file.
VITE_API_URL=
